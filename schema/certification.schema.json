{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hinoshiba.github.io/CyberSecurityCertificationRoadmap/schema/certification.schema.json",
  "title": "Certification",
  "type": "object",
  "required": ["id", "vendor", "name", "abbr", "domain", "japan_only", "official", "scoring_factors", "sources", "evaluation", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "id":     { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_-]+$" },
    "vendor": {
      "type": "object",
      "required": ["slug", "name", "url"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "url":  { "type": "string", "format": "uri" }
      }
    },
    "name":  { "type": "string", "minLength": 1 },
    "abbr":  { "type": "string", "minLength": 1 },
    "name_ja": { "type": "string" },
    "domain": { "type": "string" },
    "secondary_domains": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "japan_only": { "type": "boolean" },
    "availability": { "type": "string", "enum": ["available", "paused", "retired", "coming-soon"] },
    "availability_note": { "type": "string" },
    "official": {
      "type": "object",
      "required": ["exam_url", "fetched_at"],
      "additionalProperties": false,
      "properties": {
        "exam_url":      { "type": "string", "format": "uri" },
        "blueprint_url": { "type": "string", "format": "uri" },
        "fetched_at":    { "type": "string", "format": "date" }
      }
    },
    "logistics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cost_usd":       { "type": "number", "minimum": 0 },
        "cost_local":     { "type": "string" },
        "format":         { "type": "string" },
        "duration_min":   { "type": "integer", "minimum": 0 },
        "questions":      { "type": "integer", "minimum": 0 },
        "languages":      { "type": "array", "items": { "type": "string" } },
        "renewal_years":  { "type": "integer", "minimum": 0 },
        "ce_required":    { "type": "boolean" }
      }
    },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formal":           { "type": "array", "items": { "type": "string" } },
        "experience_years": { "type": "number", "minimum": 0 },
        "required_certs": {
          "description": "HARD prerequisites — certs the candidate MUST hold to register for / sit this exam. Always backed by an official vendor source.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": false,
            "properties": {
              "id":   { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_-]+$" },
              "url":  { "type": "string", "format": "uri" },
              "note": { "type": "string" }
            }
          }
        },
        "recommended_certs": {
          "description": "SOFT prior path — certs commonly taken before this one. Each entry carries provenance via `source` so renderers can prioritize official > inferred when capping the displayed graph.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_-]+$" },
              "source":    {
                "type": "string",
                "enum": ["official-recommended", "vendor-ladder", "community"],
                "description": "official-recommended = vendor explicitly recommends this prior cert in their docs; vendor-ladder = implied by the same-vendor tier ladder; community = third-party / industry reputation only."
              },
              "rationale": { "type": "string" },
              "url":       { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "scoring_factors": {
      "type": "object",
      "required": ["plus", "minus"],
      "additionalProperties": false,
      "properties": {
        "plus":  { "type": "array", "items": { "$ref": "#/$defs/scoring_factor" } },
        "minus": { "type": "array", "items": { "$ref": "#/$defs/scoring_factor" } }
      }
    },
    "third_party_evaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "url", "fetched_at"],
        "additionalProperties": false,
        "properties": {
          "source_id":  { "type": "string" },
          "level_hint": { "type": "string", "enum": ["introductory", "foundational", "associate", "professional", "expert", "specialty"] },
          "summary":    { "type": "string" },
          "url":        { "type": "string", "format": "uri" },
          "fetched_at": { "type": "string", "format": "date" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["official", "regulator", "third_party", "community"] },
          "url":  { "type": "string", "format": "uri" },
          "use":  { "type": "string", "enum": ["data", "inspiration_only"] },
          "name": { "type": "string" }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "computed_tier":     { "type": ["string", "null"], "enum": [null, "introductory", "foundational", "associate", "professional", "expert", "specialty"] },
        "computed_at":       { "type": ["string", "null"], "format": "date-time" },
        "computed_by_skill": { "type": ["string", "null"] },
        "rationale":         { "type": ["string", "null"] },
        "persona_scores":    {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["tier", "rationale"],
            "additionalProperties": false,
            "properties": {
              "tier":      { "type": "string", "enum": ["introductory", "foundational", "associate", "professional", "expert", "specialty"] },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },
    "schema_version": { "type": "integer", "const": 1 }
  },
  "$defs": {
    "scoring_factor": {
      "type": "object",
      "required": ["code", "weight_hint"],
      "additionalProperties": false,
      "properties": {
        "code":        { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "weight_hint": { "type": "string", "enum": ["low", "medium", "high"] },
        "evidence":    { "type": "string", "format": "uri" },
        "note":        { "type": "string" }
      }
    }
  }
}
